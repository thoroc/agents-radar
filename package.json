{
  "name": "agents-radar",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --fix src",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "manifest": "bun run src/generate-manifest.ts",
    "weekly": "bun run src/rollup/weekly.ts",
    "monthly": "bun run src/rollup/monthly.ts",
    "notify": "bun run src/notifications/notify.ts",
    "notify:feishu": "bun run src/notifications/feishu.ts",
    "scheduler": "bun run src/phases/scheduler.ts",
    "close-stale": "bun run src/close-stale-issues.ts",
    "xiaohongshu": "bun run src/notifications/social/main.ts xiaohongshu",
    "wechat": "bun run src/notifications/social/main.ts wechat",
    "wechat:monthly": "bun run src/notifications/social/main.ts wechat:monthly",
    "aislop": "aislop scan src",
    "aislop:ci": "aislop ci src",
    "aislop:fix": "aislop fix src",
    "aislop:score": "aislop scan src --json",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "generate-locale-schema": "bun run scripts/generate-locale-schema.ts",
    "validate-locales": "bun x ajv-cli validate -s locale-schema.json -d 'locales/*.json' --spec=draft2020"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@cliffy/ansi": "npm:@jsr/cliffy__ansi",
    "@cliffy/command": "npm:@jsr/cliffy__command",
    "@dotenvx/dotenvx": "^1.69.2",
    "cliffy": "^2.5.1",
    "js-yaml": "^4.1.1",
    "luxon": "^3.7.2",
    "marked": "^17.0.4",
    "openai": "^6.27.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/js-yaml": "^4.0.9",
    "@types/luxon": "^3.7.1",
    "@types/marked": "^6.0.0",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "aislop": "^0.10.1",
    "lefthook": "^2.1.9",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
